# Copia este archivo como terraform.tfvars y ajusta los valores
# cp terraform.tfvars.example terraform.tfvars
# NUNCA subas terraform.tfvars al repositorio (está en .gitignore)

aws_region            = "us-east-1"
project_name          = "franquicias-api"
environment           = "production"
key_pair_name         = "mi-keypair-aws"
ssh_allowed_cidr      = "0.0.0.0/0"   # Reemplaza con tu IP: "x.x.x.x/32"
app_instance_type     = "t3.small"
mongodb_instance_type = "t3.micro"
mongo_username        = "admin"
mongo_database        = "franquicias_db"
docker_image          = "tu-usuario-dockerhub/franquicias-api:latest"

# mongo_password se pasa como variable de entorno por seguridad:
# export TF_VAR_mongo_password="tu_password_seguro"
